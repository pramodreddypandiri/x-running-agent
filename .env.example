# ─── Required ───────────────────────────────────────────────────────────────

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your X username, without the @
X_USERNAME=your_x_handle

# Telegram bot token + chat ID — fallback used by all bots if no per-bot
# token is set below.
#
# IMPORTANT: Telegram's getUpdates is single-consumer per bot token. If you
# run more than one bot at the same time against the same token, they will
# steal each other's updates and commands will be lost. Either:
#   (a) only run one bot at a time against TELEGRAM_BOT_TOKEN, OR
#   (b) create separate BotFather bots and set the per-bot tokens below.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Optional: per-bot Telegram tokens ──────────────────────────────────────
# If set, each bot uses its own token instead of TELEGRAM_BOT_TOKEN.
# Recommended when running multiple bots simultaneously.
# WHALE_TELEGRAM_BOT_TOKEN=
# WHALE_TELEGRAM_CHAT_ID=
# MANUAL_TELEGRAM_BOT_TOKEN=
# MANUAL_TELEGRAM_CHAT_ID=
# JR_TELEGRAM_BOT_TOKEN=
# JR_TELEGRAM_CHAT_ID=
# POST_TELEGRAM_BOT_TOKEN=
# POST_TELEGRAM_CHAT_ID=
# COMMENT_TELEGRAM_BOT_TOKEN=
# COMMENT_TELEGRAM_CHAT_ID=

# ─── Optional: identity & profile ───────────────────────────────────────────
# Human display name used in inline reply prompts.
# X_DISPLAY_NAME=Your Name

# Profile URLs used by job-radar's engagement prompts.
# LINKEDIN_URL=
# GITHUB_URL=
# PORTFOLIO_URL=

# ─── Optional: file/path overrides ──────────────────────────────────────────
# SESSION_PATH=./x-session.json
# CONFIG_PATH=./config.json
# WHALE_PROMPT_PATH=./prompts/whale-prompt.txt
# MANUAL_PROMPT_PATH=./prompts/manual-prompt.txt
# JOB_RADAR_PROMPT_PATH=./prompts/job-radar-prompt.txt
# POST_PROMPT_PATH=./prompts/post-prompt.txt

# ─── Optional: Anthropic ────────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Optional: post-scheduler ───────────────────────────────────────────────
# Hour of the day (in PT) when the daily post is generated. Default: 8.
# POST_HOUR_PT=8

# ─── Optional: account discovery / RapidAPI ─────────────────────────────────
# RAPIDAPI_KEY=
