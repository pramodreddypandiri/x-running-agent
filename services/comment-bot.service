[Unit]
Description=X Comment Bot (Telegram-triggered mass commenter)
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/x-running-agent
EnvironmentFile=/root/x-running-agent/.env
ExecStart=/usr/bin/node /root/x-running-agent/comment-bot.js
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
